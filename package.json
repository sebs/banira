{
  "name": "banira",
  "version": "0.6.0",
  "description": "A toolchain for developing web components using vanilla JavaScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "banira": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "web-components",
    "vanilla-js",
    "typescript",
    "testing",
    "cli"
  ],
  "author": "Sebastian Schürmann",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebs/banira.git"
  },
  "bugs": {
    "url": "https://github.com/sebs/banira/issues"
  },
  "homepage": "https://github.com/sebs/banira#readme",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test ./test/*.test.ts",
    "lint": "tsc -p tsconfig.lint.json",
    "docs": "typedoc",
    "clean": "make clean",
    "example": "npm run build && npm run example:compile && npm run example:manifest && npm run example:doc",
    "example:compile": "node dist/cli/index.js compile examples/my-circle/my-circle.ts -o examples/my-circle/demo/dist",
    "example:manifest": "node dist/cli/index.js manifest examples/my-circle/my-circle.ts -o examples/my-circle/custom-elements.json",
    "example:doc": "node dist/cli/index.js doc examples/my-circle/my-circle.ts -o examples/my-circle/demo/doc.html",
    "example:serve": "node dist/cli/index.js serve examples/my-circle/demo",
    "example:dev": "node dist/cli/index.js dev examples/my-circle/my-circle.ts -o examples/my-circle/demo/dist -r examples/my-circle/demo",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@microsoft/tsdoc": "0.16.0",
    "ajv": "8.20.0",
    "commander": "15.0.0",
    "jsdom": "29.1.1",
    "memfs": "4.57.7",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@types/jsdom": "28.0.3",
    "@types/node": "25.9.3",
    "lightningcss": "1.32.0",
    "tsx": "4.22.4",
    "typedoc": "0.28.19"
  }
}
