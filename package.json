{
  "name": "banira",
  "version": "0.2.0",
  "description": "A toolchain for developing web components using vanilla JavaScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "banira": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "web-components",
    "vanilla-js",
    "typescript",
    "testing",
    "cli"
  ],
  "author": "Sebastian Schürmann",
  "license": "MIT",
  "engines": {
    "node": ">=18.19.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test ./test/*.test.ts",
    "lint": "tsc -p tsconfig.lint.json",
    "docs": "typedoc",
    "clean": "make clean",
    "prepare": "husky"
  },
  "dependencies": {
    "@microsoft/tsdoc": "0.15.1",
    "commander": "12.1.0",
    "jsdom": "25.0.1",
    "memfs": "4.15.1",
    "typescript": "5.7.2"
  },
  "devDependencies": {
    "@types/jsdom": "21.1.7",
    "@types/node": "22.10.2",
    "husky": "9.1.7",
    "tsx": "4.19.2",
    "typedoc": "0.27.6"
  }
}
