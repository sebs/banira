{
  "name": "@banira/component-aux",
  "version": "0.1.0",
  "description": "Clean-room vanilla web components for audio UIs (AUX-style), built with banira",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "test": "node --import tsx --test ./test/*.test.ts",
    "build": "tsc",
    "build:banira": "banira compile --project ./tsconfig.json --outDir ./dist ./src/index.ts",
    "predemo": "rm -rf ./demo && mkdir ./demo && cp -r ./dist/ ./demo/dist/",
    "demo": "banira doc ./src/widgets/aux-knob.ts -o ./demo/index.html",
    "server": "npx -y http-server ./demo",
    "showcase": "npm run build && npx -y http-server . -c-1 -o /showcase/"
  },
  "keywords": [
    "web-components",
    "banira",
    "webaudio",
    "audio-controls",
    "knob",
    "fader",
    "meter"
  ],
  "author": "Sebastian Schürmann",
  "license": "MIT",
  "engines": {
    "node": ">=18.19.0"
  },
  "dependencies": {
    "banira": "file:../banira"
  },
  "devDependencies": {
    "typescript": "5.7.2",
    "tsx": "4.7.0",
    "jsdom": "25.0.1",
    "@types/jsdom": "21.1.7",
    "@types/node": "22.10.2"
  }
}
